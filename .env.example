# --- Database ---
# A Postgres connection string. Free option: https://neon.tech (create a project, copy the "Pooled connection" string)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Auth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-byte-string"
# Local dev: http://localhost:3000  |  Production: your deployed URL (e.g. https://yourapp.vercel.app)
NEXTAUTH_URL="http://localhost:3000"

# --- Stripe (test mode) ---
# All from https://dashboard.stripe.com/test/apikeys and https://dashboard.stripe.com/test/webhooks
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# The Price ID for your $9/mo Pro plan (recurring price), from https://dashboard.stripe.com/test/products
STRIPE_PRO_PRICE_ID="price_..."
